#!/bin/sh
# pre-commit hook - Block commits containing secrets or sensitive files
#
# This hook prevents accidental commit of:
# - Files in secrets/plain/
# - .env files (*.env, .env.*)
# - Private keys (*.pem, *.key)
# - Credential files (credentials.*)
#
# To bypass (NOT RECOMMENDED): git commit --no-verify

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    # No files staged, nothing to check
    exit 0
fi

# Colors for output
if [ -t 1 ]; then
    RED='\033[0;31m'
    YELLOW='\033[1;33m'
    NC='\033[0m'
else
    RED=''
    YELLOW=''
    NC=''
fi

# Track blocked files
BLOCKED=""
BLOCKED_COUNT=0

# Check each staged file
for file in $STAGED_FILES; do
    BLOCK_REASON=""

    # Pattern 1: secrets/plain/* (plaintext secrets directory)
    case "$file" in
        secrets/plain/*)
            [ "$(basename "$file")" != ".gitkeep" ] && BLOCK_REASON="plaintext secret"
            ;;
    esac

    # Pattern 2: *.env and .env.* files
    case "$file" in
        *.env)
            BLOCK_REASON="environment file"
            ;;
        */.env.*|.env.*)
            BLOCK_REASON="environment file"
            ;;
    esac

    # Pattern 3: *.pem and *.key files (private keys)
    case "$file" in
        *.pem)
            BLOCK_REASON="private key file"
            ;;
        *.key)
            BLOCK_REASON="private key file"
            ;;
    esac

    # Pattern 4: credentials.* files
    case "$(basename "$file")" in
        credentials.*)
            BLOCK_REASON="credentials file"
            ;;
    esac

    # If blocked, add to list
    if [ -n "$BLOCK_REASON" ]; then
        BLOCKED="$BLOCKED\n  - $file ($BLOCK_REASON)"
        BLOCKED_COUNT=$((BLOCKED_COUNT + 1))
    fi
done

# If any files were blocked, abort commit
if [ "$BLOCKED_COUNT" -gt 0 ]; then
    printf "${RED}COMMIT BLOCKED${NC}\n"
    echo ""
    echo "The following $BLOCKED_COUNT file(s) contain sensitive data:"
    printf "$BLOCKED\n"
    echo ""
    printf "${YELLOW}What to do:${NC}\n"
    echo ""
    echo "  1. Unstage the sensitive files:"
    echo "     git reset HEAD <file>"
    echo ""
    echo "  2. If these are secrets that should be encrypted:"
    echo "     - Move to secrets/plain/"
    echo "     - Run: ./scripts/secrets/encrypt_all.sh"
    echo "     - Commit secrets/enc/ instead"
    echo ""
    echo "  3. If this is a false positive, add to .gitignore or use:"
    echo "     git commit --no-verify (NOT RECOMMENDED)"
    echo ""
    exit 1
fi

# Check that files marked for encryption in .gitattributes are actually encrypted
REPO_ROOT="$(git rev-parse --show-toplevel)"
GITATTRIBUTES="$REPO_ROOT/.gitattributes"
UNENCRYPTED=""
UNENCRYPTED_COUNT=0

if [ -f "$GITATTRIBUTES" ]; then
    # Extract file paths that have filter=age-crypt
    FILTERED_FILES=$(grep "filter=age-crypt" "$GITATTRIBUTES" | awk '{print $1}')

    for file in $FILTERED_FILES; do
        # Check if this file is staged
        if echo "$STAGED_FILES" | grep -q "^${file}$"; then
            # Check if the staged content starts with the age header
            HEADER=$(git show ":${file}" 2>/dev/null | head -1)
            if [ -n "$HEADER" ] && ! echo "$HEADER" | grep -q "^-----BEGIN AGE ENCRYPTED FILE-----"; then
                UNENCRYPTED="$UNENCRYPTED\n  - $file"
                UNENCRYPTED_COUNT=$((UNENCRYPTED_COUNT + 1))
            fi
        fi
    done
fi

if [ "$UNENCRYPTED_COUNT" -gt 0 ]; then
    printf "${RED}COMMIT BLOCKED${NC}\n"
    echo ""
    echo "The following $UNENCRYPTED_COUNT file(s) should be encrypted but are staged as plaintext:"
    printf "$UNENCRYPTED\n"
    echo ""
    printf "${YELLOW}What to do:${NC}\n"
    echo ""
    echo "  1. Run bootstrap to configure the encryption filter:"
    echo "     ./scripts/bootstrap.sh"
    echo ""
    echo "  2. Re-stage the files so the clean filter encrypts them:"
    echo "     ./scripts/filters/migrate-to-encrypted.sh"
    echo ""
    echo "  3. Then try committing again."
    echo ""
    exit 1
fi

# All checks passed
exit 0
